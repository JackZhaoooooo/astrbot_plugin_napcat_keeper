{
    "napcat_url": {
        "description": "NapCat WebUI 地址",
        "type": "string",
        "hint": "默认: http://localhost:6099",
        "default": "http://localhost:6099"
    },
    "napcat_token": {
        "description": "NapCat WebUI Token",
        "type": "string",
        "hint": "WebUI 登录密钥，留空则不验证",
        "default": ""
    },
    "check_interval": {
        "description": "状态检查间隔（秒）",
        "type": "int",
        "hint": "建议设置 30-120 秒",
        "default": 60
    },
    "max_retries": {
        "description": "连续失败重试次数阈值",
        "type": "int",
        "hint": "超过此次数后自动恢复 NapCat",
        "default": 3
    },
    "napcat_dir": {
        "description": "NapCat 安装目录",
        "type": "string",
        "hint": "默认: /root/AstrBot/napcat",
        "default": "/root/AstrBot/napcat"
    },
    "launcher_script": {
        "description": "NapCat 启动脚本路径",
        "type": "string",
        "hint": "默认: /root/AstrBot/napcat/launcher.sh",
        "default": "/root/AstrBot/napcat/launcher.sh"
    },
    "enable_auto_restart": {
        "description": "启用自动恢复功能",
        "type": "bool",
        "hint": "关闭后仅监控不自动恢复",
        "default": true
    },
    "enable_auto_login": {
        "description": "掉线后自动重新登录",
        "type": "bool",
        "hint": "需要配置下方的 QQ 账号密码",
        "default": true
    },
    "qq_account": {
        "description": "QQ 账号（用于自动登录）",
        "type": "string",
        "hint": "填写机器人 QQ 号",
        "default": ""
    },
    "qq_password": {
        "description": "QQ 密码（用于自动登录）",
        "type": "string",
        "hint": "留空则使用快速登录（需要先登录成功一次）",
        "default": ""
    },
    "logout_notify_umos": {
        "description": "退出登录通知",
        "type": "list",
        "hint": "填写一个或多个 UMO，会在 QQ 退出登录时主动通知",
        "items": {
            "type": "string"
        },
        "default": []
    },
    "relogin_notify_umos": {
        "description": "重新登录通知",
        "type": "list",
        "hint": "填写一个或多个 UMO，会在 QQ 重新登录时主动通知",
        "items": {
            "type": "string"
        },
        "default": []
    },
    "manual_login_notify_umos": {
        "description": "登录辅助通知",
        "type": "list",
        "hint": "当 QQ 登录需要人工验证或扫码时主动通知；留空则默认复用退出/重新登录通知目标",
        "items": {
            "type": "string"
        },
        "default": []
    },
    "auto_qr_login_fallback": {
        "description": "启用二维码登录兜底",
        "type": "bool",
        "hint": "当密码登录触发验证码/重新登录时，自动尝试获取 NapCat 二维码登录链接",
        "default": true
    },
    "manual_login_cooldown_seconds": {
        "description": "人工登录冷却时长（秒）",
        "type": "int",
        "hint": "需要验证码或扫码时，冷却期内仅轮询登录状态，不重复重启 NapCat",
        "default": 900
    },
    "manual_login_retry_interval_seconds": {
        "description": "人工登录续登重试间隔（秒）",
        "type": "int",
        "hint": "等待验证码/扫码完成后，插件会按此间隔自动重新提交登录，但不会重启 NapCat",
        "default": 20
    },
    "debug": {
        "description": "调试日志",
        "type": "bool",
        "hint": "开启后输出全部巡检日志；关闭后默认隐藏正常在线的轮询日志，但保留恢复和重新登录过程日志",
        "default": false
    },
    "notify_on_restart": {
        "description": "恢复后发送通知",
        "type": "bool",
        "hint": "自动恢复后通知管理员",
        "default": true
    }
}
