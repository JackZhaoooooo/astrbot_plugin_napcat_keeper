{
    "napcat_url": {
        "description": "NapCat 地址",
        "type": "string",
        "hint": "默认: http://localhost:6099",
        "default": "http://localhost:6099"
    },
    "napcat_token": {
        "description": "NapCat 接口 Token",
        "type": "string",
        "hint": "可选，填写后会附带 Bearer Token 请求头",
        "default": ""
    },
    "check_interval": {
        "description": "检查间隔（秒）",
        "type": "int",
        "hint": "最小 5 秒，默认 30 秒",
        "default": 30
    },
    "request_timeout_seconds": {
        "description": "请求超时（秒）",
        "type": "int",
        "hint": "最小 3 秒，默认 10 秒",
        "default": 10
    },
    "notify_umos": {
        "description": "退出登录通知 UMO 列表",
        "type": "list",
        "hint": "可填写多个 UMO，检测到退出登录时逐个通知",
        "items": {
            "type": "string"
        },
        "default": []
    },
    "debug": {
        "description": "输出全部轮询日志",
        "type": "bool",
        "hint": "关闭后仅在状态变化、告警和异常时写日志",
        "default": false
    }
}
