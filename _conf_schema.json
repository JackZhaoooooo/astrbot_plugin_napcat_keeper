{
    "napcat_url": {
        "description": "NapCat WebUI 地址",
        "type": "string",
        "hint": "默认: http://localhost:6099",
        "default": "http://localhost:6099"
    },
    "napcat_token": {
        "description": "NapCat WebUI Token",
        "type": "string",
        "hint": "WebUI 登录密钥，留空则不验证",
        "default": ""
    },
    "check_interval": {
        "description": "状态检查间隔（秒）",
        "type": "int",
        "hint": "建议设置 30-120 秒",
        "default": 60
    },
    "max_retries": {
        "description": "连续失败重试次数阈值",
        "type": "int",
        "hint": "超过此次数后自动恢复 NapCat",
        "default": 3
    },
    "napcat_dir": {
        "description": "NapCat 安装目录",
        "type": "string",
        "hint": "默认: /root/AstrBot/napcat",
        "default": "/root/AstrBot/napcat"
    },
    "launcher_script": {
        "description": "NapCat 启动脚本路径",
        "type": "string",
        "hint": "默认: /root/AstrBot/napcat/launcher.sh",
        "default": "/root/AstrBot/napcat/launcher.sh"
    },
    "enable_auto_restart": {
        "description": "启用自动恢复功能",
        "type": "bool",
        "hint": "关闭后仅监控不自动恢复",
        "default": true
    },
    "enable_auto_login": {
        "description": "掉线后自动重新登录",
        "type": "bool",
        "hint": "需要配置下方的 QQ 账号密码",
        "default": true
    },
    "qq_account": {
        "description": "QQ 账号（用于自动登录）",
        "type": "string",
        "hint": "填写机器人 QQ 号",
        "default": ""
    },
    "qq_password": {
        "description": "QQ 密码（用于自动登录）",
        "type": "string",
        "hint": "留空则使用快速登录（需要先登录成功一次）",
        "default": ""
    },
    "logout_notify_umos": {
        "description": "退出登录通知",
        "type": "list",
        "hint": "填写一个或多个 UMO，会在 QQ 退出登录时主动通知",
        "items": {
            "type": "string"
        },
        "default": []
    },
    "logout_notify_webhooks": {
        "description": "退出登录 Webhook",
        "type": "list",
        "hint": "填写一个或多个 HTTP/HTTPS Webhook 地址，会在 QQ 退出登录时以 JSON POST 通知",
        "items": {
            "type": "string"
        },
        "default": []
    },
    "relogin_notify_umos": {
        "description": "重新登录通知",
        "type": "list",
        "hint": "填写一个或多个 UMO，会在 QQ 重新登录时主动通知",
        "items": {
            "type": "string"
        },
        "default": []
    },
    "relogin_notify_webhooks": {
        "description": "重新登录 Webhook",
        "type": "list",
        "hint": "填写一个或多个 HTTP/HTTPS Webhook 地址，会在 QQ 重新登录时以 JSON POST 通知",
        "items": {
            "type": "string"
        },
        "default": []
    },
    "notification_webhook_timeout_seconds": {
        "description": "通知 Webhook 超时（秒）",
        "type": "int",
        "hint": "默认 5 秒，建议设置 3-10 秒",
        "default": 5
    },
    "notify_on_restart": {
        "description": "恢复后发送通知",
        "type": "bool",
        "hint": "自动恢复后通知管理员",
        "default": true
    }
}
