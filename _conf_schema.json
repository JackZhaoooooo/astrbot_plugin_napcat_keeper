{
    "napcat_url": {
        "description": "NapCat WebUI 地址",
        "type": "string",
        "hint": "默认: http://localhost:6099",
        "default": "http://localhost:6099"
    },
    "check_interval": {
        "description": "状态检查间隔（秒）",
        "type": "int",
        "hint": "建议设置 30-120 秒",
        "default": 60
    },
    "max_retries": {
        "description": "连续失败重试次数阈值",
        "type": "int",
        "hint": "超过此次数后自动重启 NapCat",
        "default": 3
    },
    "napcat_dir": {
        "description": "NapCat 安装目录",
        "type": "string",
        "hint": "默认: /root/AstrBot/napcat",
        "default": "/root/AstrBot/napcat"
    },
    "launcher_script": {
        "description": "NapCat 启动脚本路径",
        "type": "string",
        "hint": "默认: /root/AstrBot/napcat/launcher.sh",
        "default": "/root/AstrBot/napcat/launcher.sh"
    },
    "enable_auto_restart": {
        "description": "启用自动重启功能",
        "type": "bool",
        "hint": "关闭后仅监控不自动重启",
        "default": true
    },
    "notify_on_restart": {
        "description": "重启后发送通知",
        "type": "bool",
        "hint": "自动重启后通知管理员",
        "default": true
    }
}
